---
import Layout from '../layouts/Layout.astro';
import { listarEventos } from '../lib/api.js';

let eventos = [];
let error = null;

try {
  eventos = await listarEventos();
} catch (e) {
  error = e.message;
}

const fmt = (iso) =>
  new Date(iso).toLocaleString('es-PE', {
    dateStyle: 'medium',
    timeStyle: 'short',
  });
---

<Layout title="Eventos">
  {error && (
    <div class="max-w-5xl mx-auto px-6 pt-6">
      <div class="bg-red-50 ring-1 ring-red-600/10 text-red-700 p-4 rounded-lg">
        <p class="font-medium">Error al conectar con la API: {error}</p>
        <p class="text-sm mt-1 text-pretty">¿Está corriendo el backend en http://localhost:8000?</p>
      </div>
    </div>
  )}

  <main class="max-w-5xl mx-auto px-6 py-10">
    <header class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight text-balance">Eventos</h1>
        <p class="text-neutral-400 mt-1 text-sm text-pretty">
          {eventos.length} evento{eventos.length !== 1 ? 's' : ''} registrado{eventos.length !== 1 ? 's' : ''}
        </p>
      </div>
      <a
        href="/nuevo"
        class="bg-rose-600 hover:bg-rose-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-rose-600"
      >
        + Nuevo evento
      </a>
    </header>

    {eventos.length === 0 && !error && (
      <div class="ring-1 ring-black/5 rounded-xl p-12 text-center">
        <p class="text-neutral-400 text-pretty">Aún no hay eventos. ¡Crea el primero!</p>
      </div>
    )}

    <div class="grid md:grid-cols-2 gap-4">
      {eventos.map((ev) => (
        <article class="p-5 rounded-xl ring-1 ring-black/5 hover:ring-black/10 transition" data-id={ev.id}>
          <div class="flex justify-between items-start mb-2">
            <h2 class="font-semibold">{ev.titulo}</h2>
            <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${ev.activo ? 'bg-emerald-50 text-emerald-600 ring-1 ring-emerald-600/10' : 'bg-neutral-50 text-neutral-400 ring-1 ring-neutral-950/5'}`}>
              {ev.activo ? 'Activo' : 'Inactivo'}
            </span>
          </div>
          <p class="text-neutral-500 text-sm mb-3 text-pretty">{ev.descripcion}</p>
          <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-neutral-400">
            <span class="tabular-nums">{fmt(ev.fecha)}</span>
            <span>{ev.lugar}</span>
            <span class="tabular-nums">{ev.cupo} cupos</span>
          </div>
          <div class="mt-3 pt-3 border-t border-neutral-950/5">
            <button type="button" class="btn-eliminar text-xs text-neutral-400 hover:text-red-600 transition" data-id={ev.id}>
              Eliminar
            </button>
          </div>
        </article>
      ))}
    </div>
  </main>

  <script>
    import { eliminarEvento } from '../lib/api.js';

    document.querySelectorAll('.btn-eliminar').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const id = (e.currentTarget as HTMLElement).dataset.id;
        if (!confirm('¿Eliminar este evento?')) return;
        try {
          await eliminarEvento(id);
          window.location.reload();
        } catch (err) {
          alert('Error al eliminar: ' + err.message);
        }
      });
    });
  </script>
</Layout>
